# ---------- MongoDB ----------
# Connection string for your MongoDB cluster
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>

# Collection that holds property documents (optional, defaults to "properties")
PROPERTIES_COLLECTION=properties

# ---------- Cloudinary ----------
# Used to upload signed applications, documents and signatures
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---------- price-update scripts (optional) ----------
# Base URL used when exporting property detail links
PROPERTY_BASE_URL=https://your-domain.com/details/
# Multiplier used by reduce-prices.js (0.80 = 20% off)
PRICE_MULTIPLIER=0.80
# CSV source used by update-prices.js
CSV_FILE=./missing.csv
